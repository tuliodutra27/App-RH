# ── Copie este arquivo para .env e preencha os valores ───────────────────
# cp .env.example .env

# ── Flask ─────────────────────────────────────────────────────────────────
# Gere uma chave segura com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-uma-chave-segura-gerada-aleatoriamente

# Porta exposta pelo Docker (padrão: 5000)
APP_PORT=5000

# ── Active Directory ──────────────────────────────────────────────────────
# Endereço do servidor LDAP/AD (IP ou hostname)
AD_SERVER=ldap://192.168.1.10

# Porta LDAP (389 = padrão, 636 = LDAPS)
AD_PORT=389

# Usar SSL/LDAPS? (true/false)
AD_USE_SSL=false

# Domínio AD — usado para montar o UPN de login (usuario@DOMINIO)
AD_DOMAIN=aliseo.local

# Base DN para pesquisa no AD
AD_BASE_DN=DC=aliseo,DC=local

# CN do grupo que terá acesso ao sistema
AD_TI_GROUP_CN=TI

# ── Modo desenvolvimento (DESABILITAR em produção!) ────────────────────────
# Permite login sem AD para testes locais
DEV_MODE=false

# Usuários de teste no formato JSON (só funciona com DEV_MODE=true)
# DEV_USERS={"admin":"senha123","teste":"teste"}
DEV_USERS={}
